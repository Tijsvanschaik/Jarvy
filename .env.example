OPENAI_API_KEY=your_openai_api_key_here
EXA_API_KEY=your_exa_api_key_here

# Aiden activation and operator controls
AIDEN_ACTIVATION_SHORTCUT=F9
AIDEN_OPERATOR_SHORTCUT=CommandOrControl+Shift+O
AIDEN_INACTIVITY_MS=20000

# Provider models and voice
AIDEN_REALTIME_MODEL=gpt-realtime-2
AIDEN_REALTIME_VOICE=cedar
AIDEN_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
AIDEN_TRANSCRIPTION_FALLBACK_MODEL=whisper-1
# Comma-separated event-specific names/terms (not secrets)
AIDEN_TRANSCRIPTION_NAMES=
AIDEN_SUMMARY_MODEL=gpt-4.1-mini
AIDEN_VISION_MODEL=gpt-4.1-mini
AIDEN_RECAP_MODEL=gpt-4.1-mini
AIDEN_RECAP_IMAGE_MODEL=gpt-image-2

# Device selection and explicit path-B webcam vision
AIDEN_MICROPHONE_ID=
AIDEN_CAMERA_ID=
AIDEN_CAMERA_TIMEOUT_MS=4000
AIDEN_PROVIDER_TIMEOUT_MS=30000
AIDEN_ENABLE_CAMERA_VISION=true
AIDEN_ENABLE_RECAP=true
# Direct Realtime vision stays unsupported; path B is main-process vision.
AIDEN_VISION_PATH=B

# Storage/preflight/retention defaults
AIDEN_MIN_FREE_DISK_MB=512
AIDEN_RETENTION_DAYS=30

# Transitional inactive code; do not enable for production sessions.
AIDEN_ENABLE_COMPUTER_USE=false

# Deprecated migration fallbacks only. Prefer the AIDEN_* names above.
# RICKY_REALTIME_MODEL=
# RICKY_REALTIME_VOICE=
# RICKY_ACTIVATION_SHORTCUT=
# RICKY_OPERATOR_SHORTCUT=
# RICKY_INACTIVITY_MS=
# RICKY_TRANSCRIPTION_MODEL=
# RICKY_TRANSCRIPTION_FALLBACK_MODEL=
# RICKY_TRANSCRIPTION_NAMES=
# RICKY_SUMMARY_MODEL=
# RICKY_ENABLE_COMPUTER_USE=
